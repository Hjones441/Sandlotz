# Firebase Configuration
# Copy this file to .env.local and fill in your values from:
# Firebase Console → Project Settings → Your apps → SDK setup

NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id_here

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Sentry Error Tracking
NEXT_PUBLIC_SENTRY_DSN=https://your_dsn@sentry.io/your_project_id
SENTRY_ORG=your_sentry_org
SENTRY_PROJECT=sandlotz

# Gmail — Partnership form email notifications
# Use an App Password from myaccount.google.com/apppasswords (not your main password)
GMAIL_USER=Hjones441@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Strava API Integration
# Register at https://www.strava.com/settings/api
# Set "Authorization Callback Domain" to your domain (e.g. sandlotz.vercel.app)
NEXT_PUBLIC_STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
NEXT_PUBLIC_APP_URL=https://sandlotz.vercel.app

# Terra API — Multi-platform fitness data (Strava, Garmin, Whoop, Fitbit, etc.)
# Sign up at https://tryterra.co → Dashboard → API Keys
TERRA_API_KEY=your_terra_api_key
TERRA_DEV_ID=your_terra_dev_id
TERRA_SIGNING_SECRET=your_terra_signing_secret

# Anthropic Claude API — AI Coach feature
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your_key_here
