# Contact form email delivery
# Uncomment and configure your preferred email service

# Option A: Resend (recommended — resend.com)
# RESEND_API_KEY=re_xxxxxxxxxxxx
# CONTACT_FROM_EMAIL=website@rthreellc.com
# CONTACT_TO_EMAIL=hello@rthreellc.com

# Option B: SendGrid
# SENDGRID_API_KEY=SG.xxxxxxxxxxxx

# Option C: Simple mailto fallback (no env vars needed)
# The form will log submissions to the server console until wired up
