rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────
    function isAuthed() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuthed() && request.auth.uid == uid;
    }
    function isAdmin() {
      return isAuthed() && request.auth.token.admin == true;
    }
    function isFounder() {
      return isAuthed() && (
        request.auth.token.email == 'Hjones441@gmail.com' ||
        request.auth.token.admin == true
      );
    }

    // ── Public read-only surfaces ─────────────────────────────────────────────

    // Leaderboard entries — public read, authenticated write (own entry only)
    match /leaderboards/{city}/entries/{uid} {
      allow read: if true;
      allow write: if isOwner(uid);
    }

    // Perks catalogue — public read, founder/admin write
    match /perks/{perkId} {
      allow read:  if true;
      allow write: if isFounder();
    }

    // Brand challenges — public read, founder/admin write
    match /challenges/{id} {
      allow read:  if true;
      allow write: if isFounder();
    }

    // ── User-owned data ───────────────────────────────────────────────────────

    // User profiles — users can only read/write their own profile
    match /users/{uid} {
      allow read:  if isOwner(uid);
      allow write: if isOwner(uid);
    }

    // Activities — users can only create/read their own; score is server-validated
    // Update/delete are blocked to prevent score manipulation after logging
    match /activities/{id} {
      allow create: if isAuthed()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.score is int
        && request.resource.data.score >= 0
        && request.resource.data.score <= 100000  // sanity cap
        && request.resource.data.durationMinutes is int
        && request.resource.data.durationMinutes > 0
        && request.resource.data.durationMinutes <= 1440; // max 24h
      allow read: if isAuthed() && resource.data.uid == request.auth.uid;
      // No client-side update or delete — scores are immutable once logged
      allow update, delete: if isAdmin();
    }

    // Redemptions — users can create and read their own; transaction enforces balance
    match /redemptions/{id} {
      allow create: if isAuthed() && request.resource.data.uid == request.auth.uid;
      allow read:   if isAuthed() && resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Challenge participants — authenticated users can create/read their own entries
    match /challengeParticipants/{id} {
      allow create: if isAuthed() && request.resource.data.uid == request.auth.uid;
      allow read:   if isAuthed();
      allow update: if isAuthed() && resource.data.uid == request.auth.uid;
      allow delete: if isAdmin();
    }

    // Marketplace listings — authenticated write, public read (non-sold)
    match /marketplace/{id} {
      allow read: if true;
      allow create: if isAuthed()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.sold == false;
      allow update: if isAuthed()
        && (resource.data.uid == request.auth.uid || isAdmin());
      allow delete: if isAuthed()
        && (resource.data.uid == request.auth.uid || isAdmin());
    }

    // Partnership inquiries — anyone can submit; only admins can read
    match /partnershipInquiries/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ── Deny everything else ──────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
